        "# AND Gate using McCulloch-Pitts neuron\n",
        "def AND_gate(a, b):\n",
        "    \"\"\"\n",
        "    Implements AND logic gate using MCP neuron.\n",
        "    Inputs:\n",
        "    a, b : binary values (0 or 1)\n",
        "    Logic:\n",
        "    - Weights: [1, 1]\n",
        "    - Threshold: 2\n",
        "    Only fires (returns 1) when both inputs are 1.\n",
        "    \"\"\"\n",
        "    weights = [1, 1]\n",
        "    threshold = 2\n",
        "    return mcp_neuron([a, b], weights, threshold)\n"
      ]
    },
