        "# Define the McCulloch-Pitts neuron function\n",
        "\n",
        "def mcp_neuron(inputs, weights, threshold):\n",
        "    \"\"\"\n",
        "    Simulates a McCulloch-Pitts neuron.\n",
        "\n",
        "    Parameters:\n",
        "    inputs    : list of binary input values (0 or 1)\n",
        "    weights   : list of weights corresponding to inputs\n",
        "    threshold : numeric value for the neuron to fire\n",
        "\n",
        "    Returns:\n",
        "    1 if weighted sum >= threshold, else 0\n",
        "    \"\"\"\n",
        "    # Multiply each input by its corresponding weight and sum the results\n",
        "    total = sum(w * x for w, x in zip(weights, inputs))\n",
        "\n",
        "    # Compare sum to threshold and return binary output\n",
        "    return 1 if total >= threshold else 0\n"
      ]
    },
