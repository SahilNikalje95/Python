    "def fuzzy_union(A, B):\n",
    "    \"\"\"\n",
    "    Fuzzy Union (A U B) = max(A(x), B(x))\n",
    "    \"\"\"\n",
    "    return {x: max(A.get(x, 0), B.get(x, 0)) for x in set(A) | set(B)}\n",
    "\n",
    "def fuzzy_intersection(A, B):\n",
    "    \"\"\"\n",
    "    Fuzzy Intersection (A ∩ B) = min(A(x), B(x))\n",
    "    \"\"\"\n",
    "    return {x: min(A.get(x, 0), B.get(x, 0)) for x in set(A) | set(B)}\n",
    "\n",
    "def fuzzy_complement(A):\n",
    "    \"\"\"\n",
    "    Fuzzy Complement (~A) = 1 - A(x)\n",
    "    Note: We round to 2 decimal places to fix Python's floating-point artifacts.\n",
    "    \"\"\"\n",
    "    return {x: round(1 - A[x], 2) for x in A}\n",
    "\n",
    "def de_morgan_laws(A, B):\n",
    "    # Law 1: ~(A U B) = ~A ∩ ~B\n",
    "    lhs1 = fuzzy_complement(fuzzy_union(A, B))\n",
    "    rhs1 = fuzzy_intersection(fuzzy_complement(A), fuzzy_complement(B))\n",
    "    \n",
    "    # Law 2: ~(A ∩ B) = ~A U ~B\n",
    "    lhs2 = fuzzy_complement(fuzzy_intersection(A, B))\n",
    "    rhs2 = fuzzy_union(fuzzy_complement(A), fuzzy_complement(B))\n",
    "    \n",
    "    return lhs1, rhs1, lhs2, rhs2\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    # Example fuzzy sets\n",
    "    A = {'x1': 0.3, 'x2': 0.7, 'x3': 1.0}\n",
    "    B = {'x1': 0.5, 'x2': 0.4, 'x3': 0.8}\n",
    "    \n",
    "    # Apply De Morgan's Laws\n",
    "    lhs1, rhs1, lhs2, rhs2 = de_morgan_laws(A, B)\n",
    "    \n",
    "    # Display results cleanly\n",
    "    print(\"=========================================\")\n",
    "    print(\"Law 1: ~(A V B) = ~A ^ ~B\")\n",
    "    print(\"=========================================\")\n",
    "    print(\"LHS: \", lhs1)\n",
    "    print(\"RHS: \", rhs1)\n",
    "    \n",
    "    # Check if LHS matches RHS\n",
    "    if lhs1 == rhs1:\n",
    "        print(\"-> Law 1 is PROVED!\")\n",
    "        \n",
    "    print(\"\\n=========================================\")\n",
    "    print(\"Law 2: ~(A ^ B) = ~A V ~B\")\n",
    "    print(\"=========================================\")\n",
    "    print(\"LHS: \", lhs2)\n",
    "    print(\"RHS: \", rhs2)\n",
    "    \n",
    "    # Check if LHS matches RHS\n",
    "    if lhs2 == rhs2:\n",
    "        print(\"-> Law 2 is PROVED!\")"
   ]
